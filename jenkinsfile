// Pull latest, preserve local edits (stash → pull → pop), rebuild main frontend container.
// Aligns with deploy.txt: stash, pull, stash pop, docker-compose up -d --build
// Before up: rm alm-main-frontend avoids docker-compose 1.29.x KeyError ContainerConfig on recreate.
// Requires: agent on host that has repo + docker-compose; workspace = repo root.

pipeline {
    agent any

    options {
        // One explicit checkout below (avoids double checkout)
        skipDefaultCheckout(true)
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Stash, pull, apply') {
            steps {
                sh '''
                    set -e
                    cd "${WORKSPACE}"
                    if [ -n "$(git status --porcelain)" ]; then
                        echo "Local changes detected; stashing before pull..."
                        git stash push -u -m "wip before pull"
                        git pull --no-rebase
                        echo "Restoring stashed changes..."
                        git stash pop
                    else
                        echo "Clean tree; pulling only..."
                        git pull --no-rebase
                    fi
                '''
            }
        }

        stage('Build and run container') {
            steps {
                sh '''
                    set -e
                    cd "${WORKSPACE}"
                    # After a failed recreate, name may be <id>_alm-main-frontend; remove any match
                    docker ps -aq --filter "name=alm-main-frontend" | xargs -r docker rm -f 2>/dev/null || true
                    docker-compose up -d --build
                    docker-compose ps -a
                    docker-compose logs --tail=100
                '''
            }
        }
    }

    post {
        failure {
            echo 'Deploy failed — check console log and container status on the agent.'
        }
    }
}
